# If using gated HF models (Meta Llama etc.), set your token:
HF_TOKEN=

# Open WebUI expects a key; vLLM usually doesn't require one. Any string works.
OPENAI_API_KEY=<REQUIRE_KEY>
WEBUI_SECRET_KEY=<REQUIRE_KEY>

# WebUI DB
POSTGRES_DB=webui
POSTGRES_USER=webui
POSTGRES_PASSWORD=<REQUIRE_PWD>
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}